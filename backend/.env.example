APP_ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_LANGUAGE=ta
DEFAULT_PROJECT=highcity

PROVIDER_MODE=live
ALLOW_TEST_STUBS=false
STT_PROVIDER=sarvam
TTS_PROVIDER=sarvam
LLM_PROVIDER=groq

# Sarvam STT + TTS (single API key)
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
# codemix = Tamil-primary transcript with light English loanwords (~90/10)
SARVAM_STT_MODE=codemix
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka
SARVAM_TTS_STREAMING=true
SARVAM_TTS_WS_URL=wss://api.sarvam.ai/text-to-speech/ws
SARVAM_TTS_SAMPLE_RATE=22050
TTS_SAMPLE_RATE=22050

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_STREAMING=true

PROVIDER_TIMEOUT_SECONDS=20
PROVIDER_MAX_RETRIES=1

# Domain KB / RAG (optional HF dataset; local seed used when empty/unavailable)
# Example: HF_DATASET_ID=username/casagrand_projects_faq
HF_DATASET_ID=
HF_DATASET_SPLIT=train
# Empty = rebuild in-memory each startup (free Spaces).
# On Spaces with persistent disk: RAG_PERSIST_DIRECTORY=/data/casagrand_rag
RAG_PERSIST_DIRECTORY=
RAG_FORCE_REBUILD=false
RAG_TOP_K=3
RAG_ENABLED=true

# Twilio telephony (optional — local demo stays intact when disabled)
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Public https URL Twilio can reach (ngrok / tunnel). Required when enabled.
TWILIO_PUBLIC_BASE_URL=
TWILIO_MEDIA_STREAM_PATH=/twilio/media-stream
TWILIO_VOICE_WEBHOOK_PATH=/twilio/voice-webhook
TWILIO_STATUS_CALLBACK_PATH=/twilio/status-callback
TWILIO_VALIDATE_SIGNATURES=true
